/* 全局样式 */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 20rpx;
}

.btn {
  display: inline-block;
  padding: 15rpx 30rpx;
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 10rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

.text {
  font-size: 28rpx;
  line-height: 1.5;
  margin: 10rpx 0;
}