.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 40rpx;
  text-align: center;
}

.text {
  font-size: 30rpx;
  color: #666;
  margin: 20rpx 0;
  text-align: center;
  line-height: 1.6;
}

.btn {
  width: 100%;
  max-width: 400rpx;
  padding: 20rpx;
  background-color: #07c160;
  color: white;
  border-radius: 10rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 40rpx 0;
  transition: all 0.3s ease;
}

.btn:hover {
  opacity: 0.9;
  transform: scale(1.02);
}

.btn:active {
  transform: scale(0.98);
}