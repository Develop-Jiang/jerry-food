/* 主容器 */
.home-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF5E6 0%, #FFE4E1 50%, #E6F3FF 100%);
  padding: 20rpx;
  position: relative;
}

/* 标题栏 */
.header {
  text-align: center;
  padding: 30rpx 0;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.home-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B9D;
  text-shadow: 2rpx 2rpx 4rpx rgba(255, 107, 157, 0.3);
}

/* 房间容器 */
.room {
  position: relative;
  width: 100%;
  height: 800rpx;
  background: linear-gradient(to bottom, #FFF8DC 0%, #F5DEB3 100%);
  border-radius: 30rpx;
  border: 8rpx solid #DEB887;
  box-shadow: 
    inset 0 0 60rpx rgba(139, 69, 19, 0.1),
    0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  margin-bottom: 30rpx;
}

/* 地板 */
.floor {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, #D2691E 0%, #A0522D 100%);
  opacity: 0.3;
}

/* 墙壁装饰 */
.wall-decoration {
  position: absolute;
  font-size: 60rpx;
  animation: float 3s ease-in-out infinite;
}

.left-decor {
  top: 40rpx;
  left: 40rpx;
}

.right-decor {
  top: 40rpx;
  right: 40rpx;
  animation-delay: 1.5s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* 家具通用样式 */
.furniture {
  position: absolute;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.furniture:active {
  transform: scale(0.95);
}

.furniture-label {
  text-align: center;
  font-size: 24rpx;
  color: #FF69B4;
  margin-top: 10rpx;
  font-weight: bold;
}

/* 衣柜样式 */
.wardrobe {
  top: 150rpx;
  left: 80rpx;
  width: 280rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border: 6rpx solid #654321;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.furniture-top {
  font-size: 48rpx;
  margin-bottom: 20rpx;
}

.furniture-body {
  flex: 1;
  width: 100%;
  display: flex;
  gap: 10rpx;
}

.door {
  flex: 1;
  background: linear-gradient(135deg, #CD853F 0%, #DEB887 100%);
  border-radius: 12rpx;
  border: 4rpx solid #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.door-text {
  font-size: 32rpx;
  color: #654321;
  font-weight: bold;
}

.handle {
  position: absolute;
  right: 15rpx;
  font-size: 36rpx;
  color: #FFD700;
  font-weight: bold;
}

/* 冰箱样式 */
.fridge {
  top: 180rpx;
  right: 80rpx;
  width: 240rpx;
  height: 380rpx;
  background: linear-gradient(135deg, #87CEEB 0%, #B0E0E6 100%);
  border: 6rpx solid #4682B4;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.fridge-top {
  font-size: 44rpx;
  margin-bottom: 15rpx;
}

.fridge-body {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.fridge-door {
  flex: 1;
  background: linear-gradient(135deg, #ADD8E6 0%, #E0FFFF 100%);
  border-radius: 10rpx;
  border: 3rpx solid #4682B4;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.upper-door {
  flex: 1.2;
}

.lower-door {
  flex: 1;
}

.fridge-text {
  font-size: 28rpx;
  color: #4682B4;
  font-weight: bold;
}

/* 小桌子装饰 */
.table {
  position: absolute;
  bottom: 220rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #DEB887 0%, #D2691E 100%);
  border-radius: 60rpx;
  border: 5rpx solid #8B4513;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.2);
}

.table-text {
  font-size: 56rpx;
}

/* 底部提示 */
.footer-hint {
  text-align: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.hint-text {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 弹窗内容 */
.modal-content {
  width: 90%;
  max-width: 650rpx;
  max-height: 80vh;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: modalSlideUp 0.3s ease-out;
}

@keyframes modalSlideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF69B4 0%, #FFB6C1 100%);
  border-bottom: 4rpx solid #FF1493;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.modal-close {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  cursor: pointer;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

/* 物品网格 */
.item-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.item {
  background: linear-gradient(135deg, #FFF8DC 0%, #FFEFD5 100%);
  border-radius: 16rpx;
  padding: 25rpx 15rpx;
  text-align: center;
  border: 3rpx solid #FFD700;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.2);
  transition: all 0.3s ease;
}

.item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #FFEFD5 0%, #FFDAB9 100%);
}

.item-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 10rpx;
}

.item-name {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.item-count {
  font-size: 22rpx;
  color: #FF69B4;
  font-weight: bold;
}